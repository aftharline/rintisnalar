---
import { NAV_ITEMS } from "../../data/navigation"
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/70 backdrop-blur-xl border-b border-white/20 shadow-sm shadow-black/[0.03]">
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-18">
    <a href="#hero" class="flex items-center gap-3 group" aria-label="Beranda">
      <img src="/logo.svg" alt="Rintis Nalar" class="h-9 w-auto transition-transform duration-300 group-hover:scale-105" />
      <span class="font-sora font-bold text-ink text-lg hidden sm:inline">Rintis Nalar</span>
    </a>

    <div class="hidden md:flex items-center gap-1">
      {NAV_ITEMS.map((item) => (
        <a
          href={item.href}
          class="relative px-4 py-2 text-sm text-body hover:text-teal transition-colors font-medium rounded-full hover:bg-teal/5"
        >
          {item.label}
        </a>
      ))}
      <a
        href="#cta"
        class="ml-3 px-5 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-teal to-teal-light rounded-full hover:from-teal-dark hover:to-teal transition-all duration-300 shadow-lg shadow-teal/20 hover:shadow-teal/30"
      >
        Konsultasi Gratis
      </a>
    </div>

    <button id="menu-toggle" class="md:hidden p-2.5 text-ink hover:bg-cream rounded-xl transition-colors" aria-label="Buka menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  <div id="mobile-menu" class="md:hidden hidden bg-white/95 backdrop-blur-xl border-t border-white/20">
    <div class="px-6 py-5 flex flex-col gap-2">
      {NAV_ITEMS.map((item) => (
        <a
          href={item.href}
          class="px-4 py-3 text-body hover:text-teal hover:bg-teal/5 rounded-xl transition-all font-medium"
        >
          {item.label}
        </a>
      ))}
      <a
        href="#cta"
        class="mt-3 px-5 py-3 text-center text-sm font-semibold text-white bg-gradient-to-r from-teal to-teal-light rounded-xl transition-all"
      >
        Konsultasi Gratis
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle")
  const menu = document.getElementById("mobile-menu")

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isHidden = menu.classList.toggle("hidden")
      toggle.setAttribute("aria-label", isHidden ? "Buka menu" : "Tutup menu")
    })

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        menu.classList.add("hidden")
        toggle.setAttribute("aria-label", "Buka menu")
      })
    })
  }
</script>
