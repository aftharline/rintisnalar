---
import { ChevronDown } from "lucide-react"
import { FAQ_ITEMS } from "../../data/faq"
---

<section id="faq" class="relative overflow-hidden bg-white py-24 md:py-32 dot-pattern-light">
  <div class="glow-orb w-[500px] h-[500px] bg-teal/5 right-[-150px] top-[-100px]"></div>

  <div class="max-w-3xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <span class="text-teal/60 text-sm tracking-[0.2em] uppercase font-semibold reveal">Tanya Jawab</span>
      <h2 class="fluid-heading-lg text-ink mt-3 reveal">Pertanyaan Umum</h2>
      <p class="fluid-body text-body/70 mt-4 max-w-xl mx-auto reveal">
        Masih ragu? Temukan jawaban untuk pertanyaan yang sering diajukan.
      </p>
    </div>

    <div class="space-y-3">
      {FAQ_ITEMS.map((item, i) => (
        <details class="group border border-line/60 rounded-2xl overflow-hidden transition-all duration-300 hover:border-teal/20 open:border-teal/20 open:shadow-sm reveal" style={`transition-delay: ${i * 0.05}s`}>
          <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none text-ink font-semibold fluid-body hover:bg-cream/50 transition-colors [&::-webkit-details-marker]:hidden">
            {item.question}
            <ChevronDown size={18} strokeWidth={2} class="text-teal shrink-0 transition-transform duration-300 group-open:rotate-180" />
          </summary>
          <div class="px-6 pb-6 pt-2 text-body/80 fluid-body leading-relaxed border-t border-line/30">
            {item.answer}
          </div>
        </details>
      ))}
    </div>

    <div class="text-center mt-12 reveal">
      <p class="text-body/60 text-sm mb-4">Tidak menemukan jawaban yang Anda cari?</p>
      <a
        href="https://wa.me/6285161078616?text=Halo%20Rintis%20Nalar!%20Saya%20memiliki%20pertanyaan."
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-teal font-semibold text-sm hover:text-teal-light transition-colors"
      >
        Hubungi Kami via WhatsApp
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
