---
import { PROGRAMS } from "../../data/programs"
---

<section id="programs" class="relative overflow-hidden gradient-cream py-24 md:py-32 dot-pattern">
  <div class="glow-orb w-[500px] h-[500px] bg-teal/5 left-[-150px] top-[-100px]"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <span class="section-number reveal">Program</span>
      <h2 class="fluid-heading-lg text-ink mt-3 reveal">Program Kami</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {PROGRAMS.map((p) => (
        <div class="bg-white/80 backdrop-blur-sm p-8 rounded-2xl border border-line/60 hover:border-teal/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-500 group reveal">
          <h3 class="fluid-heading-sm text-teal mb-6 pb-4 border-b border-line/40 group-hover:text-transparent group-hover:bg-gradient-to-r group-hover:from-teal group-hover:via-teal-light group-hover:to-amber group-hover:bg-clip-text group-hover:border-teal/30 transition-all duration-500">{p.title}</h3>
          <ul class="space-y-3">
            {p.items.map((item) => (
              <li class="text-body/80 fluid-body flex items-start gap-3">
                <span class="w-2 h-2 rounded-full bg-gradient-to-r from-amber to-amber-light mt-2 shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
