---
import Layout from "../layouts/Layout.astro"
---

<Layout title="404 - Halaman Tidak Ditemukan | Rintis Nalar" description="Halaman yang Anda cari tidak ditemukan.">
  <main class="min-h-screen flex items-center justify-center bg-cream">
    <div class="text-center px-6">
      <h1 class="text-6xl md:text-8xl font-sora font-bold text-teal mb-4">404</h1>
      <p class="text-xl md:text-2xl text-ink mb-8">Halaman tidak ditemukan</p>
      <a href="/" class="inline-block bg-teal text-white px-8 py-4 rounded-full font-medium hover:bg-teal/90 transition-colors shadow-lg shadow-teal/20">
        Kembali ke Beranda
      </a>
    </div>
  </main>
</Layout>
